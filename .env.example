# NutriStudent environment template
# Copy to .env.local for local tooling only. Do not commit real secrets.

# Frontend public configuration is currently generated in utils/supabase/info.tsx.
# These are documented here for deployment checklists and future Vite env wiring.
VITE_SUPABASE_PROJECT_ID=awufigzenzypanymzoqy
VITE_SUPABASE_URL=https://awufigzenzypanymzoqy.supabase.co
VITE_SUPABASE_ANON_KEY=replace-with-public-anon-key

# RevenueCat
# Launch blocker: replace the sandbox key in src/app/services/revenuecat.ts
# with a production iOS key before App Store release.
VITE_REVENUECAT_IOS_API_KEY=replace-with-revenuecat-ios-public-key
REVENUECAT_WEBHOOK_SECRET=replace-with-revenuecat-webhook-secret
REVENUECAT_ENTITLEMENT_ID="NutriStudent Pro"

# Optional frontend error tracking; not wired until a Sentry DSN is provided.
VITE_SENTRY_DSN=

# Supabase Edge Function secrets. Set with:
# npx supabase@latest secrets set NAME=value --project-ref awufigzenzypanymzoqy
SUPABASE_URL=https://awufigzenzypanymzoqy.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
UNSPLASH_ACCESS_KEY=replace-with-unsplash-access-key
GOOGLE_PLACES_API_KEY=replace-with-google-places-api-key
CALORIE_NINJAS_API_KEY=replace-with-calorie-ninjas-api-key

# Optional backend logging. Keep false/empty in production unless debugging.
DEBUG=false
